---
import Nav from "./Nav.astro";
import DarkModeToggle from "./DarkModeToggle.astro";
---

<header class="inkrain-header">
  <a
    class="unset skip-link"
    href="#main"
  >
    Skip to content
  </a>
  <div class="header-brand">
    <span class="brand-cn">墨雨</span>
    <span class="brand-en">InkRain</span>
  </div>
  <Nav />
  <DarkModeToggle />
</header>

<style>
  .inkrain-header {
    grid-area: header;
    display: grid;
    align-items: center;
    grid-template-columns: minmax(0, max-content) minmax(0, 1fr) minmax(0, max-content);
    gap: 1rem;
    height: 4.5rem;
    border-bottom: 1px solid rgb(var(--color-border-soft));
  }

  .skip-link {
    position: absolute;
    left: 50%;
    top: -100rem;
    transform: translateX(-50%);
    background: rgb(var(--color-bg-body));
    color: rgb(var(--color-ink));
    padding: 0.5rem 1.5rem;
    z-index: 10;
    border-radius: 0 0 4px 4px;
    border: 1px solid rgb(var(--color-border));
    transition: top 0.15s ease;
  }
  .skip-link:focus {
    top: 0;
  }

  .header-brand {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    text-decoration: none;
    cursor: pointer;
  }
  .header-brand::after {
    display: none;
  }
  .brand-cn {
    font-family: "CangEr", "Kaiti SC", "STKaiti", serif;
    font-size: 1.75rem;
    line-height: 1;
    color: rgb(var(--color-ink));
    letter-spacing: 0.05em;
  }
  .brand-en {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--color-ink-muted));
  }

  @media (max-width: 768px) {
    .inkrain-header {
      grid-template-columns: minmax(0, max-content) minmax(0, 1fr) minmax(0, max-content);
    }
  }
</style>
