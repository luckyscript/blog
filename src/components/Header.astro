---
import DarkModeToggle from "./DarkModeToggle.astro";
import HeaderLink from "./HeaderLink.astro";
import { NAV } from "../config";

const navMarks: Record<string, string> = {
  首页: "雨",
  生活: "文",
  笔记: "记",
  链接: "链",
  PPT: "演",
  观察: "观",
  碎碎念: "言",
};
---

<header class="site-header" aria-label="Site navigation">
  <a class="unset skip-link" href="#main">Skip to content</a>

  <div class="header-inner">
    <a class="unset brand" href="/" aria-label="下雨就像弹钢琴">
      <span class="brand-seal" aria-hidden="true">雨</span>
      <span class="brand-text">
        <span class="brand-cn">下雨就像弹钢琴</span>
        <span class="brand-en">Rain on Piano</span>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {Object.entries(NAV).map(([name, href]) => (
        typeof href === "string" && (
          <HeaderLink href={href}>{name}</HeaderLink>
        )
      ))}
    </nav>

    <div class="header-actions">
      <DarkModeToggle />
      <button class="menu-button" id="mobile-menu-open" type="button" aria-controls="mobile-menu" aria-expanded="false">
        <i class="fa-solid fa-bars" aria-hidden="true"></i>
        <span class="fa-sr-only">Open mobile menu</span>
      </button>
    </div>
  </div>

  <section id="mobile-menu" class="mobile-menu-panel hide-menu" aria-hidden="true">
    <div class="mobile-menu-drawer">
      <div class="mobile-menu-head">
        <span class="kai-title">墨雨</span>
        <button id="mobile-menu-close" type="button" aria-label="Close mobile menu">
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
      </div>
      <nav aria-label="Mobile navigation">
        <ul class="unset">
          {Object.entries(NAV).map(([name, href]) => (
            typeof href === "string" && (
              <li>
                <HeaderLink href={href}>
                  <span class="mobile-nav-mark" aria-hidden="true">{navMarks[name] || name.slice(0, 1)}</span>
                  <span>{name}</span>
                </HeaderLink>
              </li>
            )
          ))}
        </ul>
      </nav>
    </div>
  </section>
</header>

<script>
  const openButton = document.querySelector("#mobile-menu-open");
  const closeButton = document.querySelector("#mobile-menu-close");
  const menuElem = document.querySelector("#mobile-menu");

  openButton?.addEventListener("click", () => {
    menuElem?.classList.remove("hide-menu");
    menuElem?.classList.add("show-menu");
    menuElem?.setAttribute("aria-hidden", "false");
    openButton.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  });

  closeButton?.addEventListener("click", () => {
    menuElem?.classList.remove("show-menu");
    menuElem?.classList.add("hide-menu");
    menuElem?.setAttribute("aria-hidden", "true");
    openButton?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    border-bottom: 1px solid var(--border-soft);
    backdrop-filter: blur(8px);
  }

  .header-inner {
    width: min(100%, 1080px);
    height: 72px;
    margin: 0 auto;
    padding: 0 28px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 24px;
  }

  .skip-link {
    position: absolute;
    left: 50%;
    top: -100rem;
    transform: translateX(-50%);
    background: var(--panel);
    color: var(--ink);
    padding: 0.5rem 1.5rem;
    z-index: 50;
    border: 1px solid var(--border);
  }

  .skip-link:focus {
    top: 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    background-image: none !important;
  }

  .brand-seal {
    width: 34px;
    height: 34px;
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-kai);
    font-size: 18px;
    color: var(--panel);
    background: var(--stamp);
    border: 1px solid var(--stamp);
    box-shadow: inset 0 0 0 2px var(--panel);
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
    line-height: 1.15;
  }

  .brand-cn {
    font-family: var(--font-kai);
    font-size: 1.45rem;
    color: var(--ink);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .brand-en {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .menu-button,
  #mobile-menu-close {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-soft);
    background: transparent;
    color: var(--ink);
    border-radius: 0;
    cursor: pointer;
  }

  .menu-button {
    display: none;
  }

  .mobile-menu-panel {
    position: fixed;
    inset: 0;
    z-index: 40;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    background: color-mix(in srgb, var(--ink) 18%, transparent);
  }

  .mobile-menu-drawer {
    width: min(84vw, 340px);
    height: 100%;
    background: var(--panel);
    border-right: 1px solid var(--border);
    padding: 18px;
    transform: translateX(0);
    transition: transform 0.22s ease;
  }

  .hide-menu {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .hide-menu .mobile-menu-drawer {
    transform: translateX(-100%);
  }

  .show-menu {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--border-soft);
    margin-bottom: 18px;
  }

  .mobile-menu-head .kai-title {
    font-size: 32px;
  }

  .mobile-menu-drawer ul {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 0;
    margin: 0;
  }

  .mobile-menu-drawer li {
    padding: 0 !important;
  }

  .mobile-menu-drawer li::before {
    display: none !important;
  }

  .mobile-menu-drawer :global(.inkrain-link) {
    min-height: 46px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9rem;
    background-image: none !important;
  }

  .mobile-nav-mark {
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-kai);
    color: var(--stamp);
    border: 1px solid var(--stamp);
    letter-spacing: 0;
  }

  @media (max-width: 860px) {
    .header-inner {
      height: 64px;
      padding: 0 16px;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 12px;
    }

    .desktop-nav {
      display: none;
    }

    .menu-button {
      display: inline-flex;
    }

    .brand-cn {
      font-size: 1.25rem;
      max-width: 62vw;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .brand-en {
      display: none;
    }
  }
</style>
