---
import DarkModeToggle from "./DarkModeToggle.astro";
import HeaderLink from "./HeaderLink.astro";
import { NAV } from "../config";

const railMarks: Record<string, string> = {
  首页: "全",
  生活: "文",
  笔记: "記",
  链接: "鏈",
  PPT: "演",
  观察: "觀",
  碎碎念: "言",
};
---

<header class="inkrain-header" aria-label="Site navigation">
  <a
    class="unset skip-link"
    href="#main"
  >
    Skip to content
  </a>

  <aside class="inkrain-rail" aria-label="Primary">
    <a class="unset rail-brand" href="/" aria-label="InkRain home">墨雨</a>
    <nav class="rail-nav">
      {Object.entries(NAV).map(([name, href]) => (
        typeof href === "string" && (
          <HeaderLink href={href} class="rail-link" title={name} aria-label={name}>
            <span aria-hidden="true">{railMarks[name] || name.slice(0, 1)}</span>
          </HeaderLink>
        )
      ))}
    </nav>
    <div class="rail-bottom">
      <DarkModeToggle />
      <span class="rail-version">InkRain</span>
    </div>
  </aside>

  <div class="mobile-bar">
    <a class="unset mobile-brand" href="/">
      <span class="brand-cn">墨雨</span>
      <span class="brand-en">InkRain</span>
    </a>
    <button class="mobile-menu-open" id="mobile-menu-open" type="button" aria-controls="mobile-menu" aria-expanded="false">
      <i class="fa-solid fa-bars" aria-hidden="true"></i>
      <span class="fa-sr-only">Open mobile menu</span>
    </button>
  </div>

  <section id="mobile-menu" class="mobile-menu-panel hide-menu" aria-hidden="true">
    <div class="mobile-menu-drawer">
      <div class="mobile-menu-head">
        <span class="kai-title">墨雨</span>
        <button id="mobile-menu-close" type="button">
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          <span class="fa-sr-only">Close mobile menu</span>
        </button>
      </div>
      <nav>
        <ul class="unset">
          {Object.entries(NAV).map(([name, href]) => (
            typeof href === "string" && (
              <li>
                <HeaderLink href={href}>
                  <span class="mobile-nav-mark">{railMarks[name] || name.slice(0, 1)}</span>
                  <span>{name}</span>
                </HeaderLink>
              </li>
            )
          ))}
        </ul>
      </nav>
      <div class="mobile-menu-foot">
        <DarkModeToggle />
      </div>
    </div>
  </section>
</header>

<script>
  const openButton = document.querySelector("#mobile-menu-open");
  const closeButton = document.querySelector("#mobile-menu-close");
  const menuElem = document.querySelector("#mobile-menu");

  openButton?.addEventListener("click", () => {
    menuElem?.classList.remove("hide-menu");
    menuElem?.classList.add("show-menu");
    menuElem?.setAttribute("aria-hidden", "false");
    openButton.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  });

  closeButton?.addEventListener("click", () => {
    menuElem?.classList.remove("show-menu");
    menuElem?.classList.add("hide-menu");
    menuElem?.setAttribute("aria-hidden", "true");
    openButton?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  });
</script>

<style>
  .inkrain-header {
    position: relative;
    z-index: 20;
  }

  .skip-link {
    position: absolute;
    left: 50%;
    top: -100rem;
    transform: translateX(-50%);
    background: var(--panel);
    color: var(--ink);
    padding: 0.5rem 1.5rem;
    z-index: 50;
    border-radius: 0;
    border: 1px solid var(--border);
    transition: top 0.15s ease;
  }
  .skip-link:focus {
    top: 0;
  }

  .inkrain-rail {
    position: fixed;
    inset: 0 auto 0 0;
    width: var(--rail-w);
    background: var(--panel-alt);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 18px 0;
    z-index: 30;
  }

  .rail-brand {
    font-family: var(--font-kai);
    font-size: 26px;
    color: var(--ink);
    writing-mode: vertical-rl;
    letter-spacing: 0.15em;
    line-height: 1;
    background-image: none !important;
  }

  .rail-brand::after {
    display: none;
  }

  .rail-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  :global(.rail-link) {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 !important;
    border: 1px solid transparent;
    color: var(--ink-muted);
    font-family: var(--font-kai) !important;
    font-size: 15px !important;
    letter-spacing: 0 !important;
    text-transform: none !important;
    background-image: none !important;
  }

  :global(.rail-link.show),
  :global(.rail-link:hover) {
    border-color: var(--stamp);
    color: var(--stamp);
  }

  :global(.rail-link::after) {
    display: none !important;
  }

  .rail-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  .rail-version {
    writing-mode: vertical-rl;
    font-size: 9.5px;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    line-height: 1;
  }

  .mobile-bar {
    display: none;
  }

  .brand-cn,
  .mobile-brand .brand-cn {
    font-family: var(--font-kai);
    font-size: 1.75rem;
    line-height: 1;
    color: var(--ink);
    letter-spacing: 0.05em;
  }
  .brand-en,
  .mobile-brand .brand-en {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  @media (max-width: 768px) {
    .inkrain-rail {
      display: none;
    }

    .mobile-bar {
      position: fixed;
      inset: 0 0 auto 0;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 18px;
      background: color-mix(in srgb, var(--panel) 92%, transparent);
      border-bottom: 1px solid var(--border);
      z-index: 30;
    }

    .mobile-brand {
      display: flex;
      align-items: baseline;
      gap: 10px;
      background-image: none !important;
    }

    .mobile-menu-open,
    #mobile-menu-close {
      width: 34px;
      height: 34px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--border-soft);
      background: transparent;
      color: var(--ink);
      border-radius: 0;
    }

    .mobile-menu-panel {
      position: fixed;
      inset: 0;
      z-index: 40;
      transition: transform 0.25s ease;
      background: color-mix(in srgb, var(--ink) 18%, transparent);
    }

    .mobile-menu-drawer {
      width: min(82vw, 340px);
      height: 100%;
      background: var(--panel);
      border-right: 1px solid var(--border);
      padding: 18px;
    }

    .mobile-menu-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 22px;
      border-bottom: 1px solid var(--border-soft);
      margin-bottom: 18px;
    }

    .mobile-menu-head .kai-title {
      font-size: 34px;
    }

    .mobile-menu-drawer ul {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 0;
      margin: 0;
    }

    .mobile-menu-drawer li {
      padding: 0 !important;
    }

    .mobile-menu-drawer li::before {
      display: none !important;
    }

    .mobile-menu-drawer :global(.inkrain-link) {
      min-height: 46px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.85rem;
      background-image: none !important;
    }

    .mobile-nav-mark {
      width: 30px;
      height: 30px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-kai);
      color: var(--stamp);
      border: 1px solid var(--stamp);
      letter-spacing: 0;
    }

    .mobile-menu-foot {
      margin-top: 28px;
      padding-top: 20px;
      border-top: 1px solid var(--border-soft);
    }

    .hide-menu {
      transform: translateX(-100%);
    }

    .show-menu {
      transform: translateX(0);
    }
  }
</style>
