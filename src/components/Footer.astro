<footer class="inkrain-footer">
  <span class="footer-brand">
    <a
      class="unset"
      href="https://rainonpiano.com"
    >墨雨</a>
  </span>
  <span class="footer-copy">
    &copy; 2008~{new Date().getFullYear()}
  </span>
</footer>

<style>
  .inkrain-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--ink-muted);
    border-top: 1px solid var(--border-soft);
    padding: 18px 24px;
    background: color-mix(in srgb, var(--panel) 52%, transparent);
  }
  .footer-brand a {
    font-family: var(--font-kai);
    font-size: 1.1rem;
    color: var(--stamp);
    background-image: none !important;
  }
  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
  }
</style>
