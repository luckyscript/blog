<footer class="inkrain-footer">
  <span class="footer-brand">
    <a
      class="unset"
      href="https://rainonpiano.com"
    >墨雨</a>
  </span>
  <span class="footer-copy">
    &copy; 2008~{new Date().getFullYear()}
  </span>
</footer>

<style>
  .inkrain-footer {
    grid-area: footer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: rgb(var(--color-ink-muted));
    border-top: 1px solid rgb(var(--color-border-soft));
    padding-top: 0.75rem;
  }
  .footer-brand a {
    font-family: "CangEr", "Kaiti SC", "STKaiti", serif;
    font-size: 1.1rem;
    color: rgb(var(--color-stamp));
  }
  .footer-copy {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: rgb(var(--color-ink-muted) / 0.7);
  }
</style>
