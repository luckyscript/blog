---
---
<mode-toggle class="inkrain-mode-toggle">
  <button
    class="toggle-btn"
    role="switch"
    type="button"
    tabindex="0"
    aria-checked="false"
    data-headlessui-state=""
  >
    <span class="sr-only">Toggle dark mode</span>
    <span
      class="toggle-dot invisible"
    ></span>
  </button>
</mode-toggle>

<script>
  function updateHTMLTheme(mode: "light" | "dark") {
    const themeColorMetaTag = document.head.querySelector(
      'meta[name="theme-color"]'
    );

    if (mode === "dark") {
      document.documentElement.classList.remove("light");
      document.documentElement.classList.add("dark");
      if (themeColorMetaTag) {
        // @ts-ignore
        themeColorMetaTag.content = "#15171a";
      }
    } else {
      document.documentElement.classList.remove("dark");
      document.documentElement.classList.add("light");
      if (themeColorMetaTag) {
        // @ts-ignore
        themeColorMetaTag.content = "#f5f1e8";
      }
    }
  }
  function sendMessage(message: any) {
    const iframe = document.querySelector('iframe.giscus-frame') as any;
    if (!iframe) {
      return;
    }
    iframe.contentWindow.postMessage({ giscus: message }, 'https://giscus.app');
  }

  function updateStorageTheme(mode: "light" | "dark") {
    sendMessage({
      setConfig: {
        theme: mode
      }
    });
    if (mode === "dark") {
      localStorage.setItem("theme", "dark");
    } else {
      localStorage.setItem("theme", "light");
    }
  }

  function updateToggleVisual(iconElem: Element, mode: "light" | "dark") {
    if (mode === "dark") {
      iconElem.classList.remove("light");
      iconElem.classList.add("dark");
    } else {
      iconElem.classList.remove("dark");
      iconElem.classList.add("light");
    }
  }

  function setThemeWithTransition(mode: "light" | "dark", iconElem: Element) {
    const root = document.documentElement;
    const transitionClass = mode === "dark" ? "theme-turning-dark" : "theme-turning-light";
    const applyTheme = () => {
      updateHTMLTheme(mode);
      updateStorageTheme(mode);
      updateToggleVisual(iconElem, mode);
    };

    if (
      typeof document.startViewTransition !== "function" ||
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      applyTheme();
      return;
    }

    root.classList.add(transitionClass);
    const transition = document.startViewTransition(applyTheme);
    transition.finished.finally(() => {
      root.classList.remove(transitionClass);
    });
  }

  class ModeToggle extends HTMLElement {
    constructor() {
      super();
      let currentMode: "light" | "dark" =
        document.documentElement.classList.contains("dark") ? "dark" : "light";

      const toggle = this.querySelector("button");
      const iconElem = toggle?.querySelector(".toggle-dot");

      if (iconElem) {
        if (currentMode === "dark") {
          iconElem.classList.remove("light");
          iconElem.classList.add("dark");
        } else {
          iconElem.classList.add("light");
        }

        iconElem.classList.remove("invisible");

        toggle?.addEventListener("click", () => {
          if (currentMode === "dark") {
            const modeToSwitch = "light";
            setThemeWithTransition(modeToSwitch, iconElem);
            currentMode = modeToSwitch;
          } else {
            const modeToSwitch = "dark";
            setThemeWithTransition(modeToSwitch, iconElem);
            currentMode = modeToSwitch;
          }

          if (!iconElem.classList.contains("duration-300")) {
            iconElem.classList.add("duration-300");
          }
        });
      }
    }
  }

  if (!customElements.get("mode-toggle")) {
    customElements.define("mode-toggle", ModeToggle);
  }
</script>

<style>
  .inkrain-mode-toggle {
    display: inline-flex;
  }
  .toggle-btn {
    position: relative;
    background: transparent;
    border: 1px solid rgb(var(--color-border));
    width: 34px;
    height: 34px;
    border-radius: 0;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.2s ease;
  }
  .toggle-btn:hover {
    border-color: rgb(var(--color-stamp) / 0.4);
  }
  .toggle-dot {
    position: absolute;
    inset: 8px;
    width: auto;
    height: auto;
    border-radius: 0;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }
  .toggle-dot::before {
    content: "";
    position: absolute;
    inset: 0;
    border: 1px solid rgb(var(--color-stamp));
  }
  .toggle-dot.light {
    transform: rotate(0deg);
    background: rgb(var(--color-stamp) / 0.15);
  }
  .toggle-dot.dark {
    transform: rotate(45deg);
    background: rgb(var(--color-stamp) / 0.75);
  }
</style>
