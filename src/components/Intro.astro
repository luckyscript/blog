---
---

<section class="intro-section">
  <div class="intro-inner">
    <div class="intro-seal-mark">
      <span class="mark-char">雨</span>
    </div>
    <h1>
      <span class="intro-title">
        下雨就像弹钢琴
      </span>
    </h1>
    <p class="intro-subtitle">如雨落墨，静心书写</p>
  </div>
</section>

<style>
  .intro-section {
    padding: 0;
    opacity: 0;
    animation: fadeUp 0.8s ease-out forwards;
  }
  .intro-inner {
    margin-bottom: 0.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  /* Small decorative seal mark above the title */
  .intro-seal-mark {
    width: 3.2rem;
    height: 3.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-bottom: 0.25rem;
  }
  .intro-seal-mark::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1.5px solid var(--stamp);
    border-radius: 0;
    transform: rotate(-3deg);
  }
  .mark-char {
    font-family: var(--font-kai);
    font-size: 1.55rem;
    color: var(--stamp);
    line-height: 1;
  }

  h1 {
    font-weight: 400;
    font-size: clamp(4.2rem, 12vw, 9rem);
    color: var(--ink);
    line-height: 1;
    padding: 0;
    margin: 0;
  }
  .intro-title {
    font-family: var(--font-kai);
    color: var(--ink);
    letter-spacing: 0.08em;
  }
  .intro-subtitle {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0;
    padding-bottom: 0.25rem;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
