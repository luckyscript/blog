---
import { CDN_URL } from "src/config";

/*
  InkRain font loading strategy:
  - Source Serif Pro from Google Fonts CDN (body / reading text)
  - CangEr (local) as calligraphic accent (replaces Ma Shan Zheng)
  - JetBrains Mono loaded from Google for monospace / UI labels
*/
---

<!-- Preload self-hosted calligraphic font -->
<Fragment>
  <link
    rel="preload"
    href={`${CDN_URL}/fonts/cang-er-jin-kai.ttf`}
    as="font"
    type="font/ttf"
    crossorigin="crossorigin"
  />
  <style is:inline>
    /* CangEr — calligraphic accent (replaces Ma Shan Zheng for InkRain) */
    @font-face {
      font-family: "CangEr";
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url("/fonts/cang-er-jin-kai.ttf") format("truetype");
    }

    /* Source Serif Pro — reading body text */
    @font-face {
      font-family: "Source Serif Pro";
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src:
        local("Source Serif Pro"),
        url("https://fonts.gstatic.com/s/sourceserifpro/v15/neIQsD-0qpwbpaT4wnqMTJkgk7oZuV7j5ksLepF6MjrS3GK8wV4Hs6s.woff2") format("woff2");
    }
    @font-face {
      font-family: "Source Serif Pro";
      font-style: normal;
      font-weight: 600;
      font-display: swap;
      src:
        local("Source Serif Pro"),
        url("https://fonts.gstatic.com/s/sourceserifpro/v15/neIQsD-0qpwbpaT4wnqMTJkgk7oZuV7j5ksLepF6MjrS3GK8wV4HsK0s.woff2") format("woff2");
    }

    /* JetBrains Mono — monospace UI labels */
    @font-face {
      font-family: "JetBrains Mono";
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src:
        local("JetBrains Mono"),
        url("https://fonts.gstatic.com/s/jetbrainsmono/v19/tDbY2o-flEEny0FZhsfKu5WU4zr3EibXm6xr1CE.woff2") format("woff2");
    }
    @font-face {
      font-family: "JetBrains Mono";
      font-style: normal;
      font-weight: 600;
      font-display: swap;
      src:
        local("JetBrains Mono"),
        url("https://fonts.gstatic.com/s/jetbrainsmono/v19/tDbY2o-flEEny0FZhsfKu5WU4zr3EibXm6xr4DVF.woff2") format("woff2");
    }
  </style>
</Fragment>
