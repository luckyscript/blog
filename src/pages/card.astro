---
import { readAll } from "../lib/markdoc/read";
import { card } from "../lib/markdoc/frontmatter.schema";
import PageLayout from "../layouts/PageLayout.astro";
import PageMeta from "../components/PageMeta.astro";
import { SITE_TITLE } from "../config";
import Renderer from "../components/Renderer.astro";
import VirtualScroll from "src/components/VirtualScroll.jsx";

const posts = await readAll({
  directory: "card",
  frontmatterSchema: card,
});

const sortedPosts = posts
  .filter((p) => p.frontmatter.draft !== true)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).valueOf() -
      new Date(a.frontmatter.date).valueOf()
  );
---

<PageLayout>
  <PageMeta title={`card | ${SITE_TITLE}`} slot="meta" />
  <style>
    .masonry {
      columns: 1;
    }
    /* @media (min-width: 1000px) {
      .masonry {
        columns: 2;
      }
    }
    @media (min-width: 1440px) {
      .masonry {
        columns: 3;
        width: 1440px;
        transform: translateX(-288px);
      }
    } */
    .masonry {
      column-gap: 30px;
    }
    .masonry-item {
      width: 100%;
      break-inside: avoid;
      margin-bottom: 30px;
    }
    .card-wall {
      border: 1px solid var(--border);
      background: var(--panel);
      padding: 0 0 30px;
    }
    .card-intro {
      margin: 0;
      padding: 38px 42px 32px;
      border-bottom: 1px solid var(--border-soft);
      background: var(--wash);
    }
    .card-intro h2 {
      margin: 0;
      font-family: var(--font-kai);
      font-size: clamp(2.4rem, 6vw, 4.8rem);
      line-height: 0.95;
      font-weight: 400;
      letter-spacing: 0.08em;
    }
    .card-intro p {
      margin: 14px 0 0;
      color: var(--ink-muted);
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    .ink-card-note {
      background: color-mix(in srgb, var(--panel-alt) 45%, var(--panel));
      border: 1px solid var(--border-soft);
      border-radius: 0;
      padding: 28px;
      color: var(--ink);
    }
    .ink-card-note :global(a) {
      color: var(--stamp);
    }
    .ink-card-note :global(blockquote) {
      margin: 0;
      border-left: 2px solid var(--stamp);
      padding-left: 18px;
    }
  </style>
  <section slot="main" class="card-wall">
    <header class="card-intro">
      <h2>卡片</h2>
      <p>Card · From finite matter to infinite thought</p>
    </header>
    <div class="masonry p-8">
      {
        sortedPosts.map((post) => {
          const formattedDate = new Date(
            post.frontmatter.date
          ).toLocaleDateString("en-us", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });
          return (
            <figure class="masonry-item ink-card-note">
              <div class="space-y-4 w-full">
                {post.frontmatter.tags? (
                  <div class="mono-meta">{post.frontmatter.tags.map(item =>(<a href={`/card/tag/${item}`} class="mr-2">#{item}</a>))}</div>
                ) : null}
                <blockquote class="blog-post prose prose-inkrain">
                  <object>
                    <Renderer content={post.content} />
                  </object>
                </blockquote>
                <figcaption class="mono-meta">
                  {post.frontmatter.pos ? (
                    <div>
                      笔于{" "}
                      <span>
                        {post.frontmatter.pos}
                      </span>
                    </div>
                  ) : null}
                  <div>
                    <time datetime={post.frontmatter.date.toISOString()}>
                      {formattedDate}
                    </time>
                  </div>
                </figcaption>
              </div>
            </figure>
          );
        })
      }
    </div>
  </section>
</PageLayout>
