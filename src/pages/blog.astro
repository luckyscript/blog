---
import { readBlog } from "../lib/markdoc/read";
import { blog } from "../lib/markdoc/frontmatter.schema";
import PageLayout from "../layouts/PageLayout.astro";
import PageMeta from "../components/PageMeta.astro";
import { SITE_TITLE } from "../config";

const blogs = await readBlog({
  frontmatterSchema: blog,
});

const posts = blogs
  .map(item => item.posts
    .map(post => ({ ...post, year: item.year})))
    .flat();

const sortedPosts = posts
  .filter((p) => p.frontmatter.draft !== true)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).valueOf() -
      new Date(a.frontmatter.date).valueOf()
  );
---

<PageLayout>
  <PageMeta title={`Life Blog | ${SITE_TITLE}`} slot="meta" />
  <section slot="main" class="inkrain-blog-listing">
    <h2 class="listing-heading">生活 <span class="listing-subtitle">Blog</span></h2>
    <ul>
      {
        sortedPosts.map((post) => {
          const formattedDate = new Date(
            post.frontmatter.date
          ).toLocaleDateString("zh-CN", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });
          return (
            <li class="post-row">
              {post.frontmatter.external ? (
                <a
                  href={post.frontmatter.url}
                  target="_blank"
                  class="unset post-link"
                >
                  <span class="post-title">{post.frontmatter.title}</span>
                  <span class="post-meta">
                    <span class="post-category">{post.frontmatter.category}</span>
                    <time datetime={post.frontmatter.date.toISOString()}>
                      {formattedDate}
                    </time>
                  </span>
                </a>
              ) : (
                <a
                  href={`/blog/${post.year}/${post.slug}`}
                  title={post.frontmatter.description}
                  class="unset post-link"
                >
                  <span class="post-title">{post.frontmatter.title}</span>
                  <span class="post-meta">
                    <span class="post-category">{post.frontmatter.category}</span>
                    <time datetime={post.frontmatter.date.toISOString()}>
                      {formattedDate}
                    </time>
                  </span>
                </a>
              )}
            </li>
          );
        })
      }
    </ul>
  </section>
</PageLayout>

<style>
  .inkrain-blog-listing {
    padding: 1.5rem 0 3rem;
  }
  .listing-heading {
    font-family: "CangEr", "Kaiti SC", "STKaiti", serif;
    font-size: 2rem;
    font-weight: 400;
    color: rgb(var(--color-text-heading));
    margin: 0 0 0.25rem;
    padding-left: 1rem;
    position: relative;
  }
  .listing-heading::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom, rgb(var(--color-stamp)), rgb(var(--color-stamp) / 0.3));
    border-radius: 2px;
  }
  .listing-subtitle {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    color: rgb(var(--color-ink-muted));
    letter-spacing: 0.1em;
    font-weight: 400;
  }

  .inkrain-blog-listing ul {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }

  .post-row {
    padding: 0.75rem 0;
    border-bottom: 1px solid rgb(var(--color-border-soft));
  }
  .post-row:last-child {
    border-bottom: none;
  }
  .post-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none !important;
  }
  @media (min-width: 768px) {
    .post-link {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
    }
  }
  .post-link::after {
    display: none !important;
  }
  .post-title {
    font-family: "Source Serif Pro", "Songti SC", Georgia, serif;
    font-size: 1.05rem;
    color: rgb(var(--color-ink));
    transition: color 0.2s ease;
  }
  .post-link:hover .post-title {
    color: rgb(var(--color-stamp));
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-family: "JetBrains Mono", monospace;
    color: rgb(var(--color-ink-muted));
    letter-spacing: 0.02em;
  }
  .post-category {
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    border: 1px solid rgb(var(--color-stamp) / 0.4);
    border-radius: 2px;
    color: rgb(var(--color-stamp));
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
