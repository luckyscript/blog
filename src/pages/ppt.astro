---
import { readAll } from "../lib/markdoc/read";
import { ppt } from "../lib/markdoc/frontmatter.schema";
import PageLayout from "../layouts/PageLayout.astro";
import PageMeta from "../components/PageMeta.astro";
import { SITE_TITLE } from "../config";

const posts = await readAll({
  directory: "ppt",
  frontmatterSchema: ppt,
});

const sortedPosts = posts
  .filter((p) => p.frontmatter.draft !== true)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).valueOf() -
      new Date(a.frontmatter.date).valueOf()
  );
---

<PageLayout>
  <PageMeta title={`PPT | ${SITE_TITLE}`} slot="meta" />
  <section slot="main" class="inkrain-blog-listing">
    <header class="listing-head">
      <h2 class="listing-heading">演示 <span class="listing-subtitle">PPT · Slides</span></h2>
    </header>
    <ul class="unset">
      {
        sortedPosts.map((post) => {
          const formattedDate = new Date(
            post.frontmatter.date
          ).toLocaleDateString("en-us", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });
          return (
            <li class="post-row">
                {post.frontmatter.external ? (
                  <a
                    href={post.frontmatter.url}
                    target="_blank"
                    class="unset post-link"
                  >
                    <span class="post-title">{post.frontmatter.title}</span>
                    <span class="post-meta">
                      <time datetime={post.frontmatter.date.toISOString()}>
                        {formattedDate}
                      </time>
                      <i class="fa-solid fa-up-right-from-square" aria-hidden="true" />
                    </span>
                  </a>
                ) : (
                  <a
                    href={`/ppt/${post.slug}`}
                    class="unset post-link"
                  >
                    <span class="post-title">{post.frontmatter.title}</span>
                    <span class="post-meta">
                      <time datetime={post.frontmatter.date.toISOString()}>
                        {formattedDate}
                      </time>
                    </span>
                  </a>
                )}
            </li>
          );
        })
      }
    </ul>
  </section>
</PageLayout>
