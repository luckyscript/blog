---
import PageMeta from "../components/PageMeta.astro";
import PageLayout from "../layouts/PageLayout.astro";
import Intro from "../components/Intro.astro";
import { SITE_TITLE } from "../config";
import ArmStrong from "src/components/ArmStrong.astro";
import Hyperdrive from "src/components/Hyperdrive.astro";
import Starfield from "src/components/Starfield.astro";
import PersonalDesc from "src/components/PersonalDesc.astro";
import GithubRecord from "src/components/GithubRecord.astro";
import TelegramList from 'src/components/TelegramList.astro'


import { getChannelInfo } from '../lib/telegram'

const channel = await getChannelInfo(Astro)

export const prerender = false
---

<PageLayout>
  <PageMeta title={`${SITE_TITLE} | Home`} slot="meta" />
  <Fragment slot="main">
    <Intro />
    <div class="hero-banner">
      <span class="hero-text">Never Give Up!</span>
    </div>
    <!-- <GithubRecord /> -->
    <div class="section-divider">
      <span class="divider-dot"></span>
    </div>
    <PersonalDesc />
    <div class="section-divider">
      <span class="divider-dot"></span>
    </div>
    <div class="channel-link-wrap">
      <a class="channel-link unset" href="https://channel.rainonpiano.com">
        <i class="fa-solid fa-comments"></i> 碎碎念
      </a>
    </div>
    <div class="section-divider">
      <span class="divider-dot"></span>
    </div>
    <TelegramList channel={channel} />
  </Fragment>
</PageLayout>

<style>
  .hero-banner {
    width: 100%;
    text-align: center;
    padding: 1.25rem 0;
    opacity: 0;
    animation: fadeUp 0.8s ease-out 0.2s forwards;
  }
  .hero-text {
    font-weight: 500;
    letter-spacing: 0.15em;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    color: rgb(var(--color-ink-muted));
    text-transform: uppercase;
  }

  .section-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin: 2rem auto;
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
  }
  .section-divider:nth-of-type(2) { animation-delay: 0.4s; }
  .section-divider:nth-of-type(3) { animation-delay: 0.7s; }
  .section-divider:nth-of-type(4) { animation-delay: 0.9s; }
  .divider-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgb(var(--color-ink-muted) / 0.3);
  }
  .section-divider::before,
  .section-divider::after {
    content: '';
    width: 60px;
    height: 1px;
    background: linear-gradient(to right, transparent, rgb(var(--color-border) / 0.5), transparent);
  }

  .channel-link-wrap {
    text-align: center;
    margin: 1.5rem 0;
    opacity: 0;
    animation: fadeUp 0.8s ease-out 0.6s forwards;
  }
  .channel-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    font-size: 0.9rem;
    padding: 0.45rem 1.25rem;
    border-radius: 4px;
    color: rgb(var(--color-stamp));
    border: 1px solid rgb(var(--color-stamp) / 0.3);
    font-family: "JetBrains Mono", monospace;
    transition: all 0.25s ease;
  }
  .channel-link:hover {
    border-color: rgb(var(--color-stamp) / 0.5);
    background: rgb(var(--color-stamp) / 0.05);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>
