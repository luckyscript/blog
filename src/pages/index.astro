---
import PageMeta from "../components/PageMeta.astro";
import PageLayout from "../layouts/PageLayout.astro";
import Intro from "../components/Intro.astro";
import { SITE_TITLE } from "../config";
import ArmStrong from "src/components/ArmStrong.astro";
import Hyperdrive from "src/components/Hyperdrive.astro";
import Starfield from "src/components/Starfield.astro";
import PersonalDesc from "src/components/PersonalDesc.astro";
import GithubRecord from "src/components/GithubRecord.astro";
import TelegramList from 'src/components/TelegramList.astro'


import { getChannelInfo } from '../lib/telegram'

const fallbackChannel = {
  posts: [],
  title: '碎碎念',
  description: '',
}

const channel = await Promise.race([
  getChannelInfo(Astro),
  new Promise((resolve) => setTimeout(() => resolve(fallbackChannel), 3000)),
]).catch(() => fallbackChannel)

export const prerender = false
---

<PageLayout>
  <PageMeta title={`${SITE_TITLE} | Home`} slot="meta" />
  <Fragment slot="main">
    <section class="home-sheet">
      <div class="home-wash">
        <Intro />
        <div class="hero-banner">
          <span class="hero-text">Volume 01 · Rain on piano</span>
        </div>
        <div class="ink-divider"><span class="center">墨　雨</span></div>
      </div>
    </section>
    <!-- <GithubRecord /> -->
    <section class="home-section">
      <header class="home-section-head">
        <span class="home-section-num">壹</span>
        <div>
          <div class="mono-over">Personal marks</div>
          <h2>印 · About</h2>
        </div>
      </header>
      <PersonalDesc />
    </section>

    <section class="home-section">
      <header class="home-section-head">
        <span class="home-section-num">貳</span>
        <div>
          <div class="mono-over">Micro notes</div>
          <h2>言 · Channel</h2>
        </div>
        <a class="btn-ghost unset channel-link" href="https://channel.rainonpiano.com">
          <i class="fa-solid fa-comments" aria-hidden="true"></i> 碎碎念
        </a>
      </header>
      <TelegramList channel={channel} />
    </section>
  </Fragment>
</PageLayout>

<style>
  .home-sheet,
  .home-section {
    border: 1px solid var(--border);
    background: var(--panel);
  }

  .home-sheet {
    overflow: hidden;
  }

  .home-wash {
    position: relative;
    padding: 72px 48px 54px;
    background: var(--wash);
  }

  .home-wash::before {
    content: "";
    position: absolute;
    inset: -20%;
    opacity: 0.18;
    background:
      radial-gradient(ellipse at 18% 0%, var(--ink), transparent 40%),
      radial-gradient(ellipse at 90% 100%, var(--stamp), transparent 42%);
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  .home-wash :global(.intro-section),
  .home-wash .hero-banner,
  .home-wash .ink-divider {
    position: relative;
  }

  .hero-banner {
    width: 100%;
    text-align: center;
    padding: 1.5rem 0 0;
    opacity: 0;
    animation: fadeUp 0.8s ease-out 0.2s forwards;
  }
  .hero-text {
    font-weight: 500;
    letter-spacing: 0.15em;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-muted);
    text-transform: uppercase;
  }

  .home-section {
    margin-top: 28px;
    padding: 34px 38px 38px;
  }

  .home-section-head {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding-bottom: 26px;
    border-bottom: 1px solid var(--border-soft);
    margin-bottom: 26px;
  }

  .home-section-num {
    font-family: var(--font-kai);
    font-size: 52px;
    line-height: 0.82;
    color: var(--stamp);
  }

  .home-section h2 {
    margin: 8px 0 0;
    font-family: var(--font-kai);
    font-size: 38px;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--ink);
  }

  .channel-link {
    gap: 0.5rem;
    background-image: none !important;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (max-width: 767px) {
    .home-wash {
      padding: 48px 20px 36px;
    }

    .home-section {
      padding: 26px 18px 30px;
    }

    .home-section-head {
      grid-template-columns: 44px minmax(0, 1fr);
    }

    .home-section-head .channel-link {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
</style>
